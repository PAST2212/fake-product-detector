{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-output.py",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python3 validate_verdict.py *)",
      "Bash(python3 validate_otto_verdict.py *)",
      "Bash(python3 generate_report.py *)",
      "Bash(python3 generate_otto_report.py *)",
      "Bash(python3 scripts/*)",
      "Bash(curl *)"
    ]
  }
}
